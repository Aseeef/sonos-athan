# --- Location Configuration ---
LATITUDE=0.00
LONGITUDE=0.00
TIMEZONE=America/New_York

# --- Calculation Configuration ---
# Options: MUSLIM_WORLD_LEAGUE, NORTH_AMERICA, EGYPTIAN, KARACHI, UMM_AL_QURA, etc.
CALCULATION_METHOD=NORTH_AMERICA
# Options: SHAFI, HANAFI
MADHAB=SHAFI

# --- Reminder Configuration ---
# 0 to disable, or comma-separated minutes before prayer (e.g., 5,15)
REMIND_BEFORE_MINUTES=5,15


# --- Sonos Configuration ---
# Comma-separated names, e.g., "Living Room, Kitchen". Leave empty for all speakers.
SONOS_SPEAKER_NAMES=

# --- Audio URLs ---
# Which prayers should play the full Athan MP3? 
# Comma-separated list (Fajr, Dhuhr, Asr, Maghrib, Isha). 
# If a prayer is omitted, it will use a TTS announcement instead.
PLAY_ATHAN_FOR=Fajr,Dhuhr,Asr,Maghrib,Isha
ATHAN_AUDIO_URL=https://media.assabile.com/assabile/adhan_3435370/6f509ec934a4.mp3
FAJR_ATHAN_AUDIO_URL=https://media.assabile.com/assabile/adhan_3435370/ddb21f7363eb.mp3

# --- Network Configuration ---
# Manually set your host IP if auto-detection fails (crucial for Docker)
# LOCAL_IP=192.168.1.100
SERVER_PORT=8000

# --- Volume Configuration ---
# Optional volume override (0-100) for Athan playback
ATHAN_VOLUME=60
